TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional: set to your chat ID to ignore everyone else.
ALLOWED_CHAT_ID=0

# Where the bot stores config collected via Telegram /start wizard.
CONFIG_PATH=data/config.json

# Optional: "AI agent" caption webhook
AGENT_WEBHOOK_URL=
AGENT_SHARED_SECRET=

# Default 5MB.
MAX_IMAGE_BYTES=5000000

DEBUG=false

# Platforms
ENABLE_X=true
ENABLE_LINKEDIN=true

# X API (OAuth2 user access token with tweet.write + media.write)
X_USER_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com

# LinkedIn API (OAuth2 access token)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:REPLACE_ME
LINKEDIN_VERSION=202601
